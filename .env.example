# RunnerKit live-smoke secrets (Plan 06-04).
#
# Copy this file to .env (gitignored) and paste real values. Never commit
# .env. Source before running `make smoke-live*`:
#
#   set -a; source .env; set +a
#   make smoke-live
#
# After the smoke completes, rotate any tokens that briefly lived on disk.

# Hetzner Cloud read+write token (project-scoped, NOT account-scoped).
# Console: https://console.hetzner.cloud → project → Security → API tokens.
HCLOUD_TOKEN=

# Maintainer-controlled trusted (NOT public, NOT fork) GitHub repo used
# as the smoke target. The smoke registers a real runner and immediately
# tears it down. owner/name format.
RUNNERKIT_SMOKE_REPO=accidentally-awesome-labs/dat0

# BYO smoke target host. Format: user@host or just host (must resolve and
# accept the maintainer's default SSH key without password). The smoke
# script connects, exercises the persistent BYO bootstrap, and tears the
# runner down. Required only by `make smoke-live-byo` / full smoke-live.
RUNNERKIT_SMOKE_BYO_HOST=

# Optional: how long the destroy-verify polling waits for Hetzner to
# return 404 on every saved resource ID. Default 300 seconds.
# RUNNERKIT_SMOKE_TIMEOUT=300

# Optional BYO multi-repo smoke (SEED-002): set to 1 to register a second
# private repo on the same RUNNERKIT_SMOKE_BYO_HOST after the primary `up`.
# Requires RUNNERKIT_SMOKE_REPO2 (must differ from RUNNERKIT_SMOKE_REPO).
# RUNNERKIT_SMOKE_MULTI_REPO=1
# RUNNERKIT_SMOKE_REPO2=owner/other-private-repo
