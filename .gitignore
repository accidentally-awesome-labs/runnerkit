dist/

# Live smoke artifacts (Plan 06-04). Smoke runs should be ephemeral; any
# state, log, or per-resource trace these flows write should never be
# committed.
.smoke-state/
*.smoke.log
cmd/_smokebin/empty_precheck/empty_precheck
cmd/_smokebin/destroy_verify/destroy_verify

# Local secrets for live smoke runs (HCLOUD_TOKEN, RUNNERKIT_SMOKE_BYO_HOST).
# .env.example is the public template; .env and .env.local hold real
# values and must NEVER be committed. If you pasted a secret into either
# file by mistake, rotate it immediately.
.env
.env.local
.env.*.local

# Local tooling state and built artifacts. .pi/ + .pi-lens/ are local
# meta/lens caches; bin/ holds locally compiled runnerkit binaries.
.pi/
.pi-lens/
bin/
